{
  "name": "@dotrino/vault",
  "version": "0.3.0",
  "description": "Usa ESTE dispositivo (navegador) como bóveda/CA del ecosistema Dotrino: atiende enrolamientos por el proxy y firma certificados de delegación a tus máquinas. Incluye el cliente de SERVICIO (Node): un proyecto se enrola una vez y jala sus credenciales del vault en vez del .env (`import '@dotrino/vault/config'`).",
  "type": "module",
  "main": "src/index.js",
  "module": "src/index.js",
  "bin": {
    "dotrino-env": "bin/dotrino-env.js"
  },
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./service": {
      "import": "./src/service.js"
    },
    "./env": {
      "import": "./src/env.js"
    },
    "./config": {
      "import": "./src/config.js"
    },
    "./sealed": {
      "import": "./src/sealed.js"
    },
    "./protocol": {
      "import": "./src/protocol.js"
    }
  },
  "files": [
    "src",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "dotrino",
    "vault",
    "identity",
    "delegation",
    "pairing"
  ],
  "peerDependencies": {
    "@dotrino/identity": ">=0.17.0",
    "@dotrino/proxy-client": ">=0.6.0"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/imdotrino/dotrino-vault.git",
    "directory": "lib"
  }
}
